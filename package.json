{
  "name": "@kanban/monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "Full-stack TypeScript Kanban application monorepo",
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "dev:web": "pnpm --filter @kanban/web dev",
    "dev:api": "pnpm --filter @kanban/api dev",
    "build": "pnpm -r build",
    "build:web": "pnpm --filter @kanban/web build",
    "build:api": "pnpm --filter @kanban/api build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "format": "pnpm -r format",
    "clean": "pnpm -r clean && rm -rf ./node_modules"
  },
  "devDependencies": {
    "pnpm": "^9.0.0",
    "repomix": "^1.12.0",
    "typescript": "^5.3.3"
  },
  "pnpm": {
    "overrides": {
      "typescript": "^5.3.3"
    },
    "peerDependencyRules": {
      "ignoreMissing": [
        "react",
        "react-dom"
      ]
    }
  },
  "engines": {
    "node": ">=18.17.0",
    "pnpm": ">=9.0.0"
  }
}
