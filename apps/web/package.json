    "@kanban/utils": "workspace:*",
    "@tailwindcss/postcss": "^4.2.2",
    "next": "^14.0.4",
    "postcss": "^8.5.8",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tailwindcss": "^4.2.2"
  },
  "devDependencies": {
    "@types/node": "^20.10.6",
    "@types/react": "^18.2.37",
    "@types/react-dom": "^18.2.15",
    "@types/testing-library__jest-dom": "^6.0.0",
    "eslint": "^8.56.0",
    "eslint-config-next": "^14.0.4",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.17.0"
