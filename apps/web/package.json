{
  "name": "@kanban/web",
  "version": "1.0.0",
  "description": "Next.js frontend for Kanban application",
  "private": true,
  "scripts": {
    "predev": "pnpm --filter @kanban/types --filter @kanban/utils --filter @kanban/config build",
    "dev": "next dev",
